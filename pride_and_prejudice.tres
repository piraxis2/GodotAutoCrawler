[gd_resource type="Resource" script_class="DialogueGraphResource" format=3 uid="uid://bjhdru85ecpag"]

[ext_resource type="Script" uid="uid://df6h8ox0lrqjg" path="res://addons/world_core/dialogtool/Resource/NodeDefinitions/Flow/say_def.gd" id="1_dku57"]
[ext_resource type="Script" uid="uid://cqwgrh0esffof" path="res://addons/world_core/dialogtool/Resource/NodeDefinitions/Flow/start_def.gd" id="2_nxxe4"]
