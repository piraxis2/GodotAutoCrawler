[sub_resource type="Resource" id="Resource_rf3nk"]
resource_local_to_scene = true
script = ExtResource("1_ipowr")
metadata/_custom_type_script = "uid://cqwgrh0esffof"

[sub_resource type="Resource" id="Resource_srs5m"]
script = ExtResource("2_lb6ay")
speaker = "엘리자베스"
say_text = "잠시 어색한 침묵이 흐른 뒤 두 친구는 다른 식구들이 있는 곳으로 돌아갔다. "
node_id = 1

[sub_resource type="Resource" id="Resource_rnaa1"]
script = ExtResource("2_lb6ay")
speaker = "엘리자베스"
say_text = "샬럿은 잠시 후에 떠났고, [color=blue]엘리자베스[/color]는 혼자 남아서 샬럿이 했던 말을 곱씹어 보고 있었다."
node_id = 2

[sub_resource type="Resource" id="Resource_xcetn"]
script = ExtResource("2_lb6ay")
speaker = "엘리자베스"
say_text = "두 사람이 전혀 어울리지 않는 상대라는 생각을 접기까지에는 꽤 오랜 시간이 걸렸다."
node_id = 3

[sub_resource type="Resource" id="Resource_jl7j4"]
script = ExtResource("2_lb6ay")
speaker = "엘리자베스"
say_text = "콜린스가 겨우 사흘 동안에 두 여자에게 청혼을 했다는 사실은 그의 청혼을 샬럿이 수락했다는 사실에 비하면 전혀 놀라운 일이 아니었다.  "
node_id = 4

[sub_resource type="Resource" id="Resource_xrqjc"]
script = ExtResource("2_lb6ay")
speaker = "엘리자베스"
say_text = "[color=blue]엘리자베스[/color]는 평소에 결혼에 대한 샬럿의 생각이 자신의 생각과 똑같지 않다는 건 알고 있었다."
node_id = 5

[sub_resource type="Resource" id="Resource_ldwkm"]
script = ExtResource("2_lb6ay")
speaker = "엘리자베스"
say_text = "그러나 샬럿이 막상 결혼을 결정하는 순간에 세속적인 유익을 위해 그보다 중요한 모든 감정을 희생할 수 있을 거라고는 생각하지 못했다. "
node_id = 6

[sub_resource type="Resource" id="Resource_2baf6"]
script = ExtResource("2_lb6ay")
speaker = "엘리자베스"
say_text = "콜린스의 아내가 된 샬럿의 모습은 너무도 굴욕적인 그림이었다."
node_id = 7

[sub_resource type="Resource" id="Resource_c3f3j"]
script = ExtResource("2_lb6ay")
speaker = "엘리자베"
say_text = "[color=blue]엘리자베스[/color]는 친구가 수치스러운 선택을 해서 자신을 실망시킨 것이 너무 가슴아팠다. 
그러나 그보다 더 고통스러운 건 샬럿이 스스로 선택한 운명을 행스복하게 살아 낼 수 없을 거라는 우울한 확신이었다."
node_id = 8

[sub_resource type="Resource" id="Resource_qon8t"]
